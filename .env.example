# Copie este arquivo para .env e preencha com suas credenciais reais.
# O arquivo .env NAO deve ser commitado no GitHub (ja esta no .gitignore).

# URL do projeto Supabase
SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave SECRETA do Supabase (Settings > API > service_role / secret key).
# So use no script local de importacao. NUNCA coloque no front-end!
SUPABASE_SECRET_KEY=sb_secret_COLE_SUA_CHAVE_AQUI
