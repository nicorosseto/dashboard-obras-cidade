# Copie para .env.local e preencha. O .env.local fica no .gitignore.
# Para producao/preview no Vercel, configure estas variaveis no painel do
# projeto (Settings > Environment Variables) - NAO neste arquivo.

# Use a chave PUBLISHABLE (sb_publishable_...) - NUNCA a secreta no frontend!
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_COLE_SUA_CHAVE_AQUI

# Identifica o ambiente (controla o aviso visual no topo da tela):
#   development = rodando local | preview = banco de teste | production = banco real
VITE_APP_ENV=development
